# ─────────────────────────────────────────────────────────────
# Supabase
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# service_role: SOLO se usa en webhooks y crons (nunca en el cliente)
SUPABASE_SERVICE_ROLE_KEY=

# ─────────────────────────────────────────────────────────────
# WhatsApp Cloud API (Meta) — API oficial, sin intermediarios
# ─────────────────────────────────────────────────────────────
# Token PERMANENTE de System User (Business Manager). Los temporales
# vencen a las 24 h y tiran producción.
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
# String propio que vos elegís para el handshake del webhook (GET)
WHATSAPP_VERIFY_TOKEN=
# Versión de la Graph API
WHATSAPP_GRAPH_VERSION=v21.0

# ─────────────────────────────────────────────────────────────
# Modelos de IA — cadena con fallback (dos proveedores)
# ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# Modelo primario y de respaldo (formato del AI SDK)
AGENT_MODEL_PRIMARY=claude-sonnet-4-6
AGENT_MODEL_FALLBACK=gpt-4o

# ─────────────────────────────────────────────────────────────
# Tiendanube (ecommerce) — OAuth
# ─────────────────────────────────────────────────────────────
TIENDANUBE_CLIENT_ID=
TIENDANUBE_CLIENT_SECRET=
# User-Agent obligatorio para la API de Tiendanube (nombre app + mail)
TIENDANUBE_USER_AGENT=CRM WhatsApp (mateo@zwlabs.com)

# ─────────────────────────────────────────────────────────────
# Cifrado de tokens de terceros en BD (AES-256-GCM)
# Generar con: openssl rand -hex 32  (64 caracteres hex = 32 bytes)
# ─────────────────────────────────────────────────────────────
ENCRYPTION_KEY=

# ─────────────────────────────────────────────────────────────
# Protección de los crons (header Authorization de Vercel Cron)
# Generar con: openssl rand -hex 24
# ─────────────────────────────────────────────────────────────
CRON_SECRET=

# ─────────────────────────────────────────────────────────────
# Canal admin del dueño (bot de Telegram) — opcional en esta etapa
# ─────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

# ─────────────────────────────────────────────────────────────
# App
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─────────────────────────────────────────────────────────────
# Ventanas de tiempo (ms) — ver AGENTE.md / STACK.md
# ─────────────────────────────────────────────────────────────
# Pausa del bot cuando un humano interviene (~12 h)
HUMAN_PAUSE_MS=43200000
# Deduplicado de ecos del propio CRM (~90 s)
ECHO_DEDUP_MS=90000
